{
  "name": "plataforma-kaqchikel",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma web para el aprendizaje del idioma kaqchikel.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @kaqchikel/web --filter @kaqchikel/api run dev",
    "dev:web": "pnpm --filter @kaqchikel/web run dev",
    "dev:api": "pnpm --filter @kaqchikel/api run dev",
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "db:up": "docker compose up -d postgres",
    "db:stop": "docker compose stop postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @kaqchikel/api run prisma:generate",
    "db:migrate": "pnpm --filter @kaqchikel/api run prisma:migrate",
    "db:seed": "pnpm --filter @kaqchikel/api run db:seed",
    "db:studio": "pnpm --filter @kaqchikel/api run prisma:studio"
  }
}
